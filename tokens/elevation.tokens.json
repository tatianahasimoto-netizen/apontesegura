    "keyPress": { "$value": { "color": "#0000002D", "offsetX": 0, "offsetY": 1, "blur": 0, "spread": 0 } },
    "brandLow": { "$value": { "color": "#003BE02E", "offsetX": 0, "offsetY": 2, "blur": 8, "spread": 0 } },
    "brandMedium": { "$value": { "color": "#2157EF66", "offsetX": 2, "offsetY": 8, "blur": 20, "spread": 0 } },
    "brandHigh": { "$value": { "color": "#2157EF52", "offsetX": 0, "offsetY": 12, "blur": 40, "spread": 0 } },
